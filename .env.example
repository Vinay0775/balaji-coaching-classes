# ============================================================
# TECH VIDYA INSTITUTE — Environment Configuration
# ============================================================
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# NEVER commit .env.local or .env.production to git
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# MongoDB connection string (Atlas or local)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.mongodb.net/institute-db?retryWrites=true&w=majority

# Database name (optional override - used in seed/migrate scripts)
DB_NAME=institute-db

# Environment: development | production | test
NODE_ENV=development

# ── AUTH ──────────────────────────────────────────────────────
# Must be at least 32 characters long — use: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING_MINIMUM

# Your app URL (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Admin registration secret code (students don't know this)
ADMIN_SECRET_CODE=ADMIN2024TECHVIDYA

# ── FILE STORAGE (Cloudinary) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── EMAIL (Nodemailer / Resend) ───────────────────────────────
# For Gmail SMTP:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Tech Vidya Institute <noreply@techvidya.in>

# ── APP CONFIG ────────────────────────────────────────────────
APP_URL=http://localhost:3000
APP_NAME=Tech Vidya Institute
APP_WHATSAPP=919876543210

# ── PORTS (for reference) ─────────────────────────────────────
PORT=3000
